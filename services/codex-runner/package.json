{
  "name": "@nodes/codex-runner",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "check": "node --check server.mjs && node --check server-launcher.mjs",
    "start": "node server-launcher.mjs",
    "start:env": "node --env-file=.env server-launcher.mjs",
    "dev": "node --watch server-launcher.mjs",
    "dev:env": "node --env-file=.env --watch server-launcher.mjs",
    "autostart:install:windows": "powershell -NoProfile -ExecutionPolicy Bypass -File ./install-windows-autostart.ps1",
    "autostart:remove:windows": "powershell -NoProfile -ExecutionPolicy Bypass -File ./uninstall-windows-autostart.ps1"
  }
}
