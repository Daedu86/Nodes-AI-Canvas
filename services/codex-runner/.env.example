# Bind locally by default. Use a private network/tunnel when Nodes runs remotely.
CODEX_RUNNER_HOST=127.0.0.1
CODEX_RUNNER_PORT=8787

# Shared secret used by the Nodes server when calling the runner.
CODEX_RUNNER_TOKEN=replace-with-a-long-random-secret

# Codex executable. The machine must already be authenticated with `codex login`.
CODEX_BIN=codex

# Choose one workspace strategy:
# 1) One default repository/workspace.
CODEX_DEFAULT_CWD=/absolute/path/to/your/repository
# 2) Or a JSON map from Nodes workspace/project ids to runner-owned absolute paths.
# CODEX_WORKSPACES_JSON={"project-id":"/absolute/path/to/repository"}

# Keep approvals interactive by default.
CODEX_RUNNER_AUTO_APPROVE=0
CODEX_RUNNER_REQUEST_TIMEOUT_MS=30000
CODEX_RUNNER_APPROVAL_TIMEOUT_MS=300000
