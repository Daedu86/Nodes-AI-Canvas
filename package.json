{
  "name": "nodes",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "format": "eslint . --fix",
    "format:check": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "rotate:secrets": "node --env-file=.env.local scripts/rotate-secrets.mjs",
    "setup:supabase-storage": "node --env-file=.env.local scripts/setup-supabase-storage.mjs",
    "migrate:supabase": "node --env-file=.env.local scripts/migrate-to-supabase.mjs",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:critical-coverage": "vitest run --coverage --config vitest.critical.config.ts",
    "test:e2e": "playwright test",
    "benchmark:canvas": "vitest bench --run tests/benchmarks/canvas-flow-elements.bench.js",
    "audit:production": "npm audit --omit=dev --audit-level=high",
    "audit:all": "npm audit --audit-level=critical",
    "check": "npm run format:check && npm run typecheck && npm run test:coverage && npm run test:critical-coverage",
    "test:ci": "npm run check && npm run test:e2e -- --workers=1"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.52",
    "@assistant-ui/react": "^0.12.24",
    "@assistant-ui/react-ai-sdk": "^1.3.18",
    "@assistant-ui/react-markdown": "^0.12.8",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.7",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.0",
    "@supabase/supabase-js": "^2.102.1",
    "@vercel/speed-insights": "^2.0.0",
    "@xyflow/react": "^12.10.2",
    "ai": "^6.0.141",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dagre": "^0.8.5",
    "lucide-react": "^0.511.0",
    "next": "^15.5.20",
    "next-auth": "^4.24.13",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.5.0",
    "three": "^0.183.2",
    "tw-animate-css": "^1.4.0",
    "web-streams-polyfill": "^4.2.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/dagre": "^0.7.54",
    "@types/node": "^22.19.17",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^9.39.4",
    "eslint-config-next": "^15.5.14",
    "jsdom": "^29.0.2",
    "supabase": "^2.88.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "esbuild": "^0.25.12",
    "postcss": "^8.5.10",
    "uuid": "^11.1.1"
  }
}
