OLLAMA_API_URL=http://localhost:11434/api
# Auth.js
AUTH_SECRET=replace-with-a-random-secret
NEXTAUTH_URL=http://localhost:3000
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# Local development fallback auth
AUTH_ENABLE_DEV_CREDENTIALS=1
AUTH_DEV_EMAIL=demo@nodes.local
# Do not use a known default password. Required when dev credentials are enabled.
AUTH_DEV_PASSWORD=replace-with-a-random-password
AUTH_DEV_NAME=Local Developer
# Advanced local-only route. Disabled by default in the cloud-first app flow.
# ENABLE_OLLAMA_CONTROL_ROUTE=1
# chat persistence -- sign up on cloud.assistant-ui.com
# NEXT_PUBLIC_ASSISTANT_BASE_URL=
OPENROUTER_API_KEY=your-openrouter-key
# Optional: Management key used only for automated OpenRouter key rotation
OPENROUTER_MANAGEMENT_API_KEY=
# Optional: spending limit in USD for newly rotated OpenRouter runtime keys.
# Defaults to 0.01 (one cent).
OPENROUTER_ROTATION_LIMIT_USD=0.01
# Optional: hash of the current OpenRouter runtime key to allow automatic revocation
OPENROUTER_API_KEY_HASH=
OPENROUTER_API_URL=https://openrouter.ai/api/v1
# Public-safe default:
# - By default, deployments do NOT use a shared OpenRouter key for end users.
# - Users add their own key in Profile > LLM Models and it is stored server-side.
# Set to 1 to allow using the deployment OpenRouter key as a fallback.
OPENROUTER_ALLOW_DEPLOYMENT_KEY=0
# Set to 1 to force per-user OpenRouter API keys (deployment key will be ignored even if allowed).
OPENROUTER_REQUIRE_USER_KEY=1
# Optional metadata for OpenRouter rate limiting / attribution
OPENROUTER_REFERER=http://localhost:3000
OPENROUTER_TITLE=Nodes
# Persistence backend
NODES_PERSISTENCE_BACKEND=file
# Set to 1 only for trusted remote deployments once cloud persistence is enabled.
ALLOW_REMOTE_API=0
# Security: allow remote Ollama base URLs (disabled by default).
# If enabled, consider setting an allowlist via OLLAMA_ALLOWED_HOSTNAMES.
ALLOW_OLLAMA_REMOTE_HOSTS=0
# Optional allowlist of Ollama hostnames when ALLOW_OLLAMA_REMOTE_HOSTS=1.
# Comma-separated hostnames (no scheme).
# OLLAMA_ALLOWED_HOSTNAMES=ollama.internal.example.com
# Supabase cloud persistence
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_SESSION_ARTIFACTS_BUCKET=session-artifacts
# Required only for importing old local data that has no ownerId yet
SUPABASE_MIGRATION_OWNER_ID=
# Local-only helper for CLI linking / migration workflows
SUPABASE_DB_URL=
# Requires a Supabase personal access token with API key read/write permissions
SUPABASE_ACCESS_TOKEN=
# Cloud-first defaults used by the app when no local overrides are set
DEFAULT_MODEL=nvidia/nemotron-3-super-120b-a12b:free
NEXT_PUBLIC_DEFAULT_MODEL=nvidia/nemotron-3-super-120b-a12b:free
NEXT_PUBLIC_DEFAULT_PROVIDER=openrouter
# Optional local-first example instead:
# DEFAULT_MODEL=gemma3:4b
# NEXT_PUBLIC_DEFAULT_MODEL=gemma3:4b
# NEXT_PUBLIC_DEFAULT_PROVIDER=ollama
